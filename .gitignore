*.pyc
__pycache__/
.venv/
*.egg-info/
.DS_Store

# Subject runtime data (large NIfTI volumes from scans)
murfi/subjects/sub-*/img/
murfi/subjects/sub-*/rest/
murfi/subjects/sub-*/xfm/
murfi/subjects/sub-*/mask/*.nii
murfi/subjects/sub-*/log/
murfi/subjects/sub-*/fsfs/
murfi/subjects/sub-*/qc/

# DICOM input (received from scanner, transient)
murfi/dicom_input/*.dcm

# Session logs
murfi/logs/*.log

# Dry-run cache (populated from real session data)
murfi/dry_run_cache/

# Real-BOLD dry-run cache (downloaded from public datasets via
# scripts/fetch_dry_run_bold.py — enables meaningful FSL rehearsal)
murfi/dry_run_cache_bold/
