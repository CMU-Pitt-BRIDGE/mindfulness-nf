<?xml version="1.0" encoding="UTF-8"?>
<study name="rtDMN">
    <option name="softwareDir"> /opt/murfi/ </option>
</study>

<scanner>
  <option name="disabled">     false </option>
  <option name="tr">             1.2 </option>
  <option name="measurements">    2 </option>
  <option name="port">           50000 </option>
  <!-- `save` enables disk writes; `saveImages` enables in-memory accept.
       Both are needed to land raw img-*.nii on disk. See rtdmn.xml for
       background on the missing `save` option (Bug C, sub-morgan). -->
  <option name="save">           true </option>
  <option name="saveImages">     true </option>
  <option name="receiveImages">  true </option>
  <option name="onlyReadMoCo">  true </option>
</scanner>

<infoserver>
  <option name="disabled"> false </option>
  <option name="port"> 15001 </option>
</infoserver>

<!-- processing steps (every TR)-->
<processor>
  <!-- creats a mosaic for the GUI -->
  <module name="mosaic">
    <option name="disabled"> false </option>
    <output>display</output>
    <output>log</output>
  </module>

  
</processor>
